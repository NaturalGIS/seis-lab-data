{
  "survey_missions": [
    {
      "name": {
        "pt": "missão1 owf-seism-2024",
        "en": "first mission owf-seism-2024"
      },
      "description": {
        "pt": "Descrição da missão1",
        "en": "Description for first mission"
      },
      "relative_path": "surveys/owf-seism-2024/",
      "records": [
        "record_batch_1"
      ]
    }
  ],
  "records": {
    "record_batch_1": {
      "dataset_category": "bathymetry",
      "domain_type": "geophysical",
      "workflow_stage": "processed data",
      "metadata_extractor": "seis_lab_data.extractors.bathymetry.extractor_default_or_customizable",
      "name": {
        "pt": "Batimetria processada",
        "en": "Final processed bathymetry"
      },
      "assets": [
        {
          "name": {
            "pt": "Ficheiro tif",
            "en": "xyz file"
          },
          "discovery_patterns": [
            "s06-mbes/s05-processed-data/s02-dtm-points/{date}/{area}_All_Mainlines_and_Xlines_MBES_Grid_{grid_resolution}.tif"
          ]
        },
        {
          "name": {
            "pt": "Ficheiro xyz",
            "en": "xyz file"
          },
          "discovery_patterns": [
            "s06-mbes/s05-processed-data/s02-dtm-points/{date}/{area}_All_Mainlines_and_Xlines_MBES_Grid_{grid_resolution}.xyz"
          ]
        }
      ],
      "extra_properties": {
        "date": {
          "extractor": {
            "pattern": "\\d{8}",
            "converter": "datetime.fromisoformat"
          },
          "matcher": {
            "type": "datetime",
            "delta_below_seconds": 3600
          }
        },
        "area": {
          "extractor": {
            "pattern": "\\w{3}",
            "converter": "str"
          },
          "matcher": {
            "type": "constant",
            "choices": ["FIG", "ALM", "LIS"],
            "match_type": "equal"
          }
        },
        "grid_resolution": {
          "extractor": {
            "pattern": "\\d\\w",
            "converter": "str"
          },
          "matcher": {
            "type": "constant",
            "choices": ["4m", "8m"],
            "match_type": "any"
          }
        }
      }
    }
  },
  "record_relations" : []
}
