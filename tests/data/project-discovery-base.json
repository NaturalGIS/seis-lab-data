{
  "survey_missions": [
    {
      "name": {
        "pt": "missão1 owf-seism-2024",
        "en": "first mission owf-seism-2024"
      },
      "description": {
        "pt": "Descrição da missão1",
        "en": "Description for first mission"
      },
      "relative_path": "surveys/owf-seism-2024/",
      "records": [
        "raw_bathy",
        "processed_bathy"
      ]
    }
  ],
  "records": {
    "raw_bathy": {
      "dataset_category": "bathymetry",
      "domain_type": "geophysical",
      "workflow_stage": "raw data",
      "metadata_extractor": "seis_lab_data.extractors.bathymetry.extractor_default_or_customizable",
      "name": {"pt": "Batimetria em bruto", "en": "Raw bathymetry"},
      "assets": [
        {
          "name": {"pt": "Ficheiro kmall", "en": "kmall file"},
          "discovery_patterns": ["s06-mbes/s02-raw-data/01-EM712/{date-dashed}/\\d{4}_{date}_\\d{6}_MarioRuivo.kmall"]
        }
      ],
      "extra_properties": {
        "date": {
          "extractor": {"pattern": "\\d{8}", "converter": "datetime.fromisoformat"},
          "matcher": {"type": "datetime", "delta_below_seconds": 3600}
        },
        "date-dashed": {
          "extractor": {"pattern": "\\d{4}-\\d{2}-\\d{2}", "converter": "seis_lab_data.filesystemextractors.get_data_dashed"},
          "matcher": {"type": "datetime", "delta_below_seconds": 3600}
        }
      }
    },
    "processed_bathy": {
      "dataset_category": "bathymetry",
      "domain_type": "geophysical",
      "workflow_stage": "processed data",
      "metadata_extractor": "seis_lab_data.extractors.bathymetry.extractor_default_or_customizable",
      "name": {"pt": "Batimetria processada", "en": "Processed bathymetry"},
      "assets": [
        {
          "name": {"pt": "Ficheiro xyz", "en": "xyz file"},
          "discovery_patterns": ["s06-mbes/s05-processed-data/{region}_All_Mainlines?_and_Xlines?_MBES_Grid_4m.xyz"]
        }
      ],
      "extra_properties": {
        "region": {
          "extractor": {"pattern": "[A-Z]{3}", "converter": "str"},
          "matcher": {"type": "constant", "choices": ["FIG", "LEI"], "match_type":  "equal"}
        }
      }
    },
    "raw_uhrs_line": {
      "dataset_category": "uhrs",
      "domain_type": "geoseismic",
      "workflow_stage": "raw data",
      "metadata_extractor": "seis_lab_data.extractors.bathymetry.extractor_default_or_customizable",
      "name": {"pt": "Sísmica UHRS raw", "en": "UHRS raw"},
      "assets": [
        {
          "name": {"pt": "twt", "en": "twt"},
          "discovery_patterns": ["s13-uhrs/s02-raw-data/BACKED UP - FIGUEIRA/FIG-24-{mark}/FIG-24-{mark}_rev1.segy"]
        }
      ],
      "extra_properties": {
        "mark": {
          "extractor": {"pattern": "[A-Z](\\d\\d\\d(_\\d)?)?", "converter": "str"},
          "matcher": {"type": "constant", "match_type":  "equal"}
        }
      }
    }
  },
  "record_relations" : []
}
